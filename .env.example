NODE_ENV=development
PORT=3000
API_BASE_URL=https://todoapp-backend-delta.vercel.app

# Recomendado para Neon, Railway, Render y Vercel.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DATABASE_URL_UNPOOLED=

# Alternativa para PostgreSQL local.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=todoapp
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# Sequelize sync es práctico en desarrollo. En producción usa migraciones.
DB_SYNC=true
DB_SYNC_ALTER=false

JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
CRON_SECRET=replace_with_a_random_secret_of_at_least_16_characters

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

CORS_ORIGIN=*
REMINDER_CRON=*/1 * * * *
REMINDER_LOOKAHEAD_MINUTES=5
TZ=America/Bogota
